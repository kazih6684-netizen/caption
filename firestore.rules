rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Config: Public can read, Admin can write
    match /config/app {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'kazih6684@gmail.com';
    }

    // Main Slots: Open write to support password-managed mentor access
    match /mainSlots/{slotId} {
      allow read, list: if true;
      allow write: if true;
    }

    // Content Items: Open write to support password-managed mentor access
    match /contentItems/{itemId} {
      allow read, list: if true;
      allow write: if true;
    }

    // Channels: Public can read, Admin can write
    match /channels/{channelId} {
      allow read, list: if true;
      allow write: if request.auth != null && request.auth.token.email == 'kazih6684@gmail.com';
    }

    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
